{{!
    Template: mod_pharos_badges/evidence_view
    Context:
      id     - Course module ID
      levels - Array of { level, level_label, count, threshold, percent, badge_earned, evidence_items[] }
               evidence_items: { type, description, date, date_iso }
}}
<div class="pharos-badges" role="region" aria-labelledby="pharos-badges-heading">

    <h2 id="pharos-badges-heading" class="h4 mb-3">{{#str}}pageheading, mod_pharos_badges{{/str}}</h2>

    {{! Explanation banner }}
    <div class="alert alert-info d-flex align-items-start mb-4" role="note">
        <span class="mr-2" aria-hidden="true" style="font-size:1.4rem">🤖</span>
        <div>
            <strong>{{#str}}ai_evidence_title, mod_pharos_badges{{/str}}</strong><br>
            <small>{{#str}}ai_evidence_info, mod_pharos_badges{{/str}}</small>
        </div>
    </div>

    {{#levels}}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center"
             id="pharos-badges-level-{{level}}-header">
            <span class="pharos-level-badge pharos-level-badge--n{{level}}">{{level_label}}</span>
            {{#badge_earned}}
            <span class="badge badge-success" aria-label="{{#str}}badge_earned, mod_pharos_badges{{/str}}">
                🎖 {{#str}}badge_earned, mod_pharos_badges{{/str}}
            </span>
            {{/badge_earned}}
            {{^badge_earned}}
            <small class="text-muted"
                   aria-label="{{count}} {{#str}}de, mod_pharos_badges{{/str}} {{threshold}} {{#str}}evidencias_requeridas, mod_pharos_badges{{/str}}">
                <span aria-hidden="true">{{count}} / {{threshold}}</span>
                {{#str}}evidencias_requeridas, mod_pharos_badges{{/str}}
            </small>
            {{/badge_earned}}
        </div>
        <div class="card-body">

            {{! Progress bar }}
            <div class="pharos-xp-bar mb-3"
                 role="progressbar"
                 aria-valuenow="{{percent}}"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-label="{{level_label}}: {{percent}}%">
                <div class="pharos-xp-bar__fill" style="width:{{percent}}%"></div>
            </div>

            {{! Evidence list }}
            <ul class="list-unstyled mb-0"
                aria-label="{{#str}}evidencias_enviadas, mod_pharos_badges{{/str}}">
                {{#evidence_items}}
                <li class="d-flex align-items-start mb-2">
                    <span class="badge badge-secondary mr-2 flex-shrink-0 text-wrap text-left"
                          style="max-width:90px">
                        <span class="sr-only">{{#str}}tipo, mod_pharos_badges{{/str}}: </span>{{type}}
                    </span>
                    <span class="flex-grow-1 small">{{description}}</span>
                    <time class="text-muted ml-2 flex-shrink-0 small" datetime="{{date_iso}}">{{date}}</time>
                </li>
                {{/evidence_items}}
                {{^evidence_items}}
                <li class="text-muted small" role="status">
                    {{#str}}no_evidence_yet, mod_pharos_badges{{/str}}
                </li>
                {{/evidence_items}}
            </ul>

        </div>
    </div>
    {{/levels}}

</div>
