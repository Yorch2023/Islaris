{{!
    Template: mod_pharos_badges/evidence_view
    Context:
      id          - Course module ID
      sesskey     - Moodle session key
      can_submit  - bool
      levels      - Array of { level, level_label, count, threshold, percent, badge_earned, evidence_items[] }
      types       - Array of { value, label }
}}
<div class="pharos-badges">

    {{#levels}}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="pharos-level-badge pharos-level-badge--n{{level}}">{{level_label}}</span>
            {{#badge_earned}}
            <span class="badge badge-success">{{#str}}badge_earned, mod_pharos_badges{{/str}}</span>
            {{/badge_earned}}
            {{^badge_earned}}
            <small class="text-muted">{{count}} / {{threshold}} {{#str}}evidencias_requeridas, mod_pharos_badges{{/str}}</small>
            {{/badge_earned}}
        </div>
        <div class="card-body">

            {{! Progress bar }}
            <div class="pharos-xp-bar mb-3" role="progressbar"
                 aria-valuenow="{{percent}}" aria-valuemin="0" aria-valuemax="100">
                <div class="pharos-xp-bar__fill" style="width:{{percent}}%"></div>
            </div>

            {{! Evidence list }}
            {{#evidence_items}}
            <div class="d-flex align-items-start mb-2">
                <span class="badge badge-secondary mr-2 flex-shrink-0">{{type}}</span>
                <span class="flex-grow-1">{{description}}</span>
                <small class="text-muted ml-2 flex-shrink-0">{{date}}</small>
            </div>
            {{/evidence_items}}
            {{^evidence_items}}
            <p class="text-muted small mb-0">{{#str}}no_evidence_yet, mod_pharos_badges{{/str}}</p>
            {{/evidence_items}}

        </div>
    </div>
    {{/levels}}

    {{! Submit evidence form }}
    {{#can_submit}}
    <div class="card">
        <div class="card-header font-weight-bold">{{#str}}submit_evidence, mod_pharos_badges{{/str}}</div>
        <div class="card-body">
            <form method="post" action="">
                <input type="hidden" name="sesskey" value="{{sesskey}}">

                <div class="form-group">
                    <label for="evidence-level">{{#str}}nivel, mod_pharos_badges{{/str}}</label>
                    <select id="evidence-level" name="evidence_level" class="form-control" required>
                        <option value="1">N1 — Fundamentos</option>
                        <option value="2">N2 — IA en la práctica</option>
                        <option value="3">N3 — Facilitación crítica</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="evidence-type">{{#str}}tipo_evidencia, mod_pharos_badges{{/str}}</label>
                    <select id="evidence-type" name="evidence_type" class="form-control" required>
                        {{#types}}
                        <option value="{{value}}">{{label}}</option>
                        {{/types}}
                    </select>
                </div>

                <div class="form-group">
                    <label for="evidence-description">{{#str}}descripcion_evidencia, mod_pharos_badges{{/str}}</label>
                    <textarea id="evidence-description" name="evidence_description"
                              class="form-control" rows="3" maxlength="1000" required></textarea>
                </div>

                <button type="submit" class="btn btn-danger">
                    {{#str}}submit_evidence, mod_pharos_badges{{/str}}
                </button>
            </form>
        </div>
    </div>
    {{/can_submit}}

</div>
