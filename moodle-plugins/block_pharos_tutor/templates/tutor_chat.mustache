{{!
    Template: block_pharos_tutor/tutor_chat
    Context:
      proxy_url        - URL of the Moodle AJAX proxy (ajax.php)
      stream_proxy_url - URL of the SSE streaming proxy (ajax-stream.php)
      user_id          - Moodle user ID (string)
      user_level       - Itinerary level (1, 2 or 3)
      lang             - 'es' or 'it'
      sesskey          - Moodle session key for CSRF protection
      strings          - Object with localised UI strings
}}
{{! Skip link — allows keyboard users to jump straight to the input }}
<a href="#pharos-tutor-input" class="sr-only sr-only-focusable">
    {{strings.skip_to_input}}
</a>

<div class="pharos-tutor"
     data-proxy-url="{{proxy_url}}"
     data-stream-proxy-url="{{stream_proxy_url}}"
     data-session-url="{{session_url}}"
     data-memory-url="{{memory_url}}"
     data-course-id="{{course_id}}"
     data-user-id="{{user_id}}"
     data-level="{{user_level}}"
     data-lang="{{lang}}"
     data-sesskey="{{sesskey}}"
     role="region"
     aria-labelledby="pharos-tutor-heading">

    <h3 id="pharos-tutor-heading" class="sr-only">{{strings.pluginname}}</h3>

    {{! Message log — aria-live so screen readers announce new messages }}
    <div class="pharos-tutor__messages"
         id="pharos-tutor-messages"
         role="log"
         aria-live="polite"
         aria-atomic="false"
         aria-label="{{strings.messages_label}}"
         tabindex="0">
        <div class="pharos-tutor__message pharos-tutor__message--assistant">
            <span class="pharos-tutor__avatar" aria-hidden="true"></span>
            <div class="pharos-tutor__bubble">{{strings.welcome}}</div>
        </div>
    </div>

    {{! Visually hidden status for screen readers }}
    <div class="pharos-tutor__status pharos-tutor__status--hidden"
         id="pharos-tutor-status"
         role="status"
         aria-live="polite"
         aria-atomic="true"
         data-error-text="{{strings.error}}">
        {{strings.thinking}}
    </div>

    {{! Session progress — hidden, updated by JS }}
    <div class="pharos-tutor__session-progress"
         id="pharos-tutor-session-progress"
         aria-live="polite"
         aria-atomic="true"></div>

    {{! Evidence toast — shown when an AI session creates an evidence record }}
    <div class="pharos-tutor__evidence-toast pharos-tutor__evidence-toast--hidden"
         id="pharos-tutor-evidence-toast"
         role="status"
         aria-live="polite"
         aria-atomic="true">
        {{strings.evidence_registered}}
    </div>

    <form class="pharos-tutor__form"
          id="pharos-tutor-form"
          novalidate
          aria-label="{{strings.form_label}}">
        <label for="pharos-tutor-input" class="sr-only">{{strings.placeholder}}</label>
        <textarea
            id="pharos-tutor-input"
            class="pharos-tutor__input form-control"
            name="message"
            rows="2"
            placeholder="{{strings.placeholder}}"
            maxlength="4000"
            aria-required="true"
            aria-describedby="pharos-tutor-char-count"></textarea>
        <div id="pharos-tutor-char-count"
             class="pharos-tutor__char-count sr-only"
             aria-live="polite"></div>
        <button type="submit"
                class="pharos-tutor__send btn btn-primary"
                aria-label="{{strings.send}}">
            <span aria-hidden="true">&#9658;</span> {{strings.send}}
        </button>
    </form>
</div>
