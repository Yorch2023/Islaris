# PHAROS-AI · Variables de entorno
# Copia este archivo a .env y rellena los valores
#
# Para uso local con Docker:
#   1. cp .env.example .env
#   2. Pon tu clave de IA (Groq es gratis; Anthropic requiere créditos)
#   3. docker-compose up -d

# === OPCIÓN A: GROQ (gratis) ===
# Crea cuenta y obtén clave en: https://console.groq.com
# Cuando GROQ_API_KEY está presente, el middleware usa Groq (llama-3.1-8b-instant).
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX
# Modelo opcional (por defecto: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.3-70b-versatile

# === OPCIÓN B: ANTHROPIC / CLAUDE API (requiere créditos) ===
# Obtén tu clave en: https://console.anthropic.com/settings/keys
# Solo se usa si GROQ_API_KEY está vacío o no definido.
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# === MIDDLEWARE ===
PORT=3001
NODE_ENV=development

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost,http://localhost:8080,https://tu-moodle.ejemplo.com

# === SEGURIDAD ===
# Token secreto compartido entre Moodle y el middleware.
# En local puedes dejar este valor; cámbialo en producción.
MOODLE_SECRET=pharos_local_secret_2024

# === MOODLE REST API ===
MOODLE_URL=http://localhost:8080
MOODLE_WS_TOKEN=token_webservice_moodle

# === BASE DE DATOS (PostgreSQL) ===
MOODLE_DB_HOST=localhost
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=pharos_moodle
MOODLE_DB_USER=pharos
MOODLE_DB_PASS=cambia_esta_contrasena

# === RATE LIMITING ===
# Llamadas máximas por usuario por hora
RATE_LIMIT_TUTOR=20
RATE_LIMIT_GENERATOR=10
RATE_LIMIT_ADVISOR=15
RATE_LIMIT_MEMORY=20
