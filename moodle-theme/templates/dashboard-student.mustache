{{!
    Template: theme_pharos/dashboard-student
    Context:
      fullname        - Student full name
      level           - Current itinerary level (1/2/3)
      level_label     - e.g. "N1 — Fundamentos"
      xp_current      - XP earned
      xp_next         - XP needed for next level
      xp_percent      - Integer 0-100
      badges          - Array of { name, image_url, earned (bool) }
      activities      - Array of { name, url, completed (bool), due_date }
      days_inactive   - Days since last activity (0 = active today)
}}
<div class="pharos-itinerary">

    {{! Header }}
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">{{#str}}mi_itinerario, mod_pharos_itinerary{{/str}}</h2>
        <span class="pharos-level-badge pharos-level-badge--n{{level}}">
            {{level_label}}
        </span>
    </div>

    {{! XP Progress }}
    <div class="mb-4">
        <div class="pharos-xp-bar" role="progressbar"
             aria-valuenow="{{xp_percent}}" aria-valuemin="0" aria-valuemax="100"
             aria-label="Progreso XP">
            <div class="pharos-xp-bar__fill" data-target-width="{{xp_percent}}%"></div>
        </div>
        <p class="pharos-xp-label">{{xp_current}} / {{xp_next}} XP</p>
    </div>

    {{! Activity list }}
    <div class="card mb-4">
        <div class="card-header">{{#str}}actividades, mod_pharos_itinerary{{/str}}</div>
        <ul class="list-group list-group-flush">
            {{#activities}}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span class="{{#completed}}text-muted{{/completed}}">
                    {{#completed}}<span aria-hidden="true">&#10003;&nbsp;</span>{{/completed}}
                    {{^completed}}<span aria-hidden="true">&#9675;&nbsp;</span>{{/completed}}
                    <a href="{{url}}" class="{{#completed}}text-muted text-decoration-line-through{{/completed}}">
                        {{name}}
                    </a>
                </span>
                {{#due_date}}<small class="text-muted ml-2">{{due_date}}</small>{{/due_date}}
            </li>
            {{/activities}}
        </ul>
    </div>

    {{! Badges }}
    <h3 class="h6 mb-3">{{#str}}microcredenciales, mod_pharos_badges{{/str}}</h3>
    <div class="row">
        {{#badges}}
        <div class="col-4">
            <div class="pharos-badge-card {{#earned}}pharos-badge-card--earned{{/earned}}">
                <img src="{{image_url}}" alt="{{name}}" loading="lazy">
                <p class="mb-0 small">{{name}}</p>
            </div>
        </div>
        {{/badges}}
    </div>

</div>
